{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/grokify/systemforge/identity/coreauth/config.schema.json",
  "properties": {
    "issuer": {
      "type": "string",
      "format": "uri",
      "description": "OAuth/OIDC issuer URL"
    },
    "database": {
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "postgres",
            "sqlite",
            "mysql"
          ],
          "description": "Database driver"
        },
        "dsn": {
          "type": "string",
          "description": "Database connection string (supports env var expansion)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "driver",
        "dsn"
      ],
      "description": "Database configuration for persistent storage"
    },
    "keys": {
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "RS256",
            "ES256"
          ],
          "description": "JWT signing algorithm",
          "default": "RS256"
        },
        "rotation_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Key rotation interval in days (0 = never)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Signing key configuration"
    },
    "tokens": {
      "properties": {
        "access_token_lifetime": {
          "type": "string",
          "pattern": "^(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$",
          "description": "Access token lifetime (e.g. 15m",
          "default": "15m",
          "examples": [
            "15m",
            "1h",
            "168h",
            "720h"
          ]
        },
        "refresh_token_lifetime": {
          "type": "string",
          "pattern": "^(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$",
          "description": "Refresh token lifetime (e.g. 168h",
          "default": "168h",
          "examples": [
            "15m",
            "1h",
            "168h",
            "720h"
          ]
        },
        "id_token_lifetime": {
          "type": "string",
          "pattern": "^(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$",
          "description": "ID token lifetime (e.g. 1h)",
          "default": "1h",
          "examples": [
            "15m",
            "1h",
            "168h",
            "720h"
          ]
        },
        "auth_code_lifetime": {
          "type": "string",
          "pattern": "^(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$",
          "description": "Authorization code lifetime (e.g. 10m)",
          "default": "10m",
          "examples": [
            "15m",
            "1h",
            "168h",
            "720h"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Token lifetime configuration"
    },
    "clients": {
      "items": {
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique client identifier"
          },
          "secret": {
            "type": "string",
            "description": "Client secret (supports env var expansion)"
          },
          "type": {
            "type": "string",
            "enum": [
              "public",
              "confidential"
            ],
            "description": "Client type"
          },
          "name": {
            "type": "string",
            "description": "Human-readable client name"
          },
          "description": {
            "type": "string",
            "description": "Client description"
          },
          "redirect_uris": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "Allowed redirect URIs"
          },
          "grant_types": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "Allowed OAuth grant types"
          },
          "response_types": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "Allowed OAuth response types"
          },
          "scopes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "Allowed OAuth scopes"
          },
          "audience": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "Allowed token audiences"
          },
          "access_token_lifetime": {
            "type": "string",
            "pattern": "^(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$",
            "description": "Client-specific access token lifetime",
            "examples": [
              "15m",
              "1h",
              "168h",
              "720h"
            ]
          },
          "refresh_token_lifetime": {
            "type": "string",
            "pattern": "^(\\d+(\\.\\d+)?(ns|us|µs|ms|s|m|h))+$",
            "description": "Client-specific refresh token lifetime",
            "examples": [
              "15m",
              "1h",
              "168h",
              "720h"
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "type",
          "name"
        ]
      },
      "type": "array",
      "description": "Static OAuth client configurations"
    },
    "federation": {
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable CoreControl federation"
        },
        "corecontrol_url": {
          "type": "string",
          "format": "uri",
          "description": "CoreControl server URL"
        },
        "app_id": {
          "type": "string",
          "description": "Application ID in the federation"
        },
        "client_id": {
          "type": "string",
          "description": "OAuth client ID for CoreControl"
        },
        "client_secret": {
          "type": "string",
          "description": "OAuth client secret (supports env var expansion)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "CoreControl federation configuration"
    },
    "features": {
      "properties": {
        "require_pkce": {
          "type": "boolean",
          "description": "Require PKCE for authorization code flows",
          "default": true
        },
        "allow_dynamic_registration": {
          "type": "boolean",
          "description": "Enable dynamic client registration (RFC 7591)",
          "default": false
        },
        "enable_device_flow": {
          "type": "boolean",
          "description": "Enable device authorization grant (RFC 8628)",
          "default": false
        },
        "enable_jwt_access_tokens": {
          "type": "boolean",
          "description": "Issue JWT access tokens instead of opaque tokens",
          "default": false
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Feature flags"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "issuer"
  ],
  "title": "CoreAuth Configuration",
  "description": "Configuration schema for CoreAuth OAuth 2.0 / OpenID Connect server"
}